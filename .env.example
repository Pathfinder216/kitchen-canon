# Environment for docker compose (production deploy). Copy to `.env` and fill in.
# `.env` is git-ignored; the deploy script auto-generates one on the Pi if missing.

# REQUIRED: secret used to sign session + CSRF cookies. Must be at least 32 characters.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=

# Optional: session lifetime in hours (default 720 = 30 days).
# SESSION_TTL_HOURS=720

# Optional: whether auth cookies require HTTPS. Defaults to true (the app is served behind the
# host's nginx reverse proxy over HTTPS). Set to false only for a throwaway plain-HTTP test.
# COOKIE_SECURE=true

# Signup invite code. Registration always checks the submitted code against this value. Empty (the
# default) means an empty code is valid → open signup; set it to a secret to gate registration.
# Generate + share one with: openssl rand -hex 8. The deploy script generates one on first deploy.
# Recommended for an internet-facing instance.
# SIGNUP_INVITE_CODE=

# The public DNS name the app is served at (the DuckDNS subdomain pointing at this Pi). Used by
# the deploy script's final message. TLS + routing for it live in the host nginx vhost + certbot,
# not in the container, so the app itself does not consume this.
# APP_DOMAIN=your-name.duckdns.org
