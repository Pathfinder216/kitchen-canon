generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique // stored lowercased
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  recipes       Recipe[]
  mealPlans     MealPlan[]
  substitutions IngredientSubstitution[] @relation("UserSubstitutions")
  preferences   UserPreferences?
  sessions      Session[]
  catalogItems  IngredientCatalog[]
  aliases       IngredientAlias[]
  labels        Label[]
  localizations LocalizationMapping[]
}

model Session {
  id        String   @id @default(uuid()) // opaque id placed in the cookie
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Recipe {
  id            String   @id @default(uuid())
  title         String
  servings      Int      @default(1)
  source        String?  // Original URL or source name
  archived      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Versioning
  version    Int      @default(1)
  parentId   String?
  parent     Recipe?  @relation("RecipeVersions", fields: [parentId], references: [id])
  versions   Recipe[] @relation("RecipeVersions")
  isLatest   Boolean  @default(true)

  // Notes
  authorNotes   String?
  personalNotes String?

  // Relations
  ingredients Ingredient[]
  steps       Step[]
  media       Media[]
  courses     RecipeCourse[]
  labels      RecipeLabel[]
  mealRecipes MealRecipe[]

  @@index([userId])
}

model Ingredient {
  id           String             @id @default(uuid())
  recipeId     String
  recipe       Recipe             @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  name         String             // Standardized name
  originalName String?            // Original name from source
  amount       Float?
  unit         String?
  isOptional   Boolean            @default(false)
  note         String?            // Per-recipe note, e.g. "use Cooper brand", "chopped into 1-inch cubes"
  orderIndex   Int                // Display order
  catalogId    String?
  catalog      IngredientCatalog? @relation(fields: [catalogId], references: [id], onDelete: SetNull)
}

model Step {
  id           String  @id @default(uuid())
  recipeId     String
  recipe       Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  orderIndex   Int
  instruction  String  // Can include {butter:50%} for "50% of the 'butter' ingredient"
  timeMinutes  Float?
  isActiveTime Boolean @default(true)
  media        Media[]
}

model Media {
  id       String  @id @default(uuid())
  type     String  // 'image' | 'video'
  path     String  // File path or URL
  orderIndex Int?
  recipeId String?
  recipe   Recipe? @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  stepId   String?
  step     Step?   @relation(fields: [stepId], references: [id], onDelete: Cascade)
}

enum CourseType {
  APPETIZER
  SOUP
  SALAD
  BREAD
  MAIN
  SIDE
  DESSERT
  BREAKFAST
  SNACK
  DRINK
  TOPPING
}

model RecipeCourse {
  recipeId   String
  courseType CourseType
  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@id([recipeId, courseType])
}

model Label {
  id      String        @id @default(uuid())
  type    String        // 'dietary', 'allergen', 'manual'
  name    String
  userId  String?       // null = global/seeded, non-null = user's private label
  user    User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipes RecipeLabel[]

  @@unique([type, name, userId])
  @@index([userId])
}

model RecipeLabel {
  recipeId String
  labelId  String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  label    Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([recipeId, labelId])
}

model IngredientSubstitution {
  id             String  @id @default(uuid())
  fromIngredient String  // Standardized ingredient name
  toIngredient   String  // Substitute ingredient name
  ratio          Float   // Conversion ratio
  notes          String?
  createdBy      String? // null = official/global, non-null = owning user id
  user           User?   @relation("UserSubstitutions", fields: [createdBy], references: [id], onDelete: Cascade)
  isOfficial     Boolean @default(false)

  @@index([createdBy])
}

model LocalizationMapping {
  id            String @id @default(uuid())
  locale        String // e.g., "en-US", "en-GB"
  originalName  String
  localizedName String
  userId        String? // null = global/seeded, non-null = user's private mapping
  user          User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([locale, originalName, userId])
  @@index([userId])
}

model MealPlan {
  id          String    @id @default(uuid())
  name        String?
  date        String?   // ISO date string e.g. "2024-01-15"
  time        String?   // Time string e.g. "18:30"
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  cookedAt    DateTime?
  dietaryInfo Json?     // { allergens: string[], diets: string[], unknownIngredients: string[] }
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipes     MealRecipe[]
  groceryList GroceryItem[]

  @@index([userId])
}

model IngredientCatalog {
  id           String            @id @default(uuid())
  displayAlias String            // Human-readable display name shown in UI
  allergens    Json              @default("[]") // string[]
  diets        Json              @default("[]") // string[] — diets this ingredient is compatible with
  isUserAdded  Boolean           @default(false)
  createdAt    DateTime          @default(now())
  userId       String?           // null = global/seeded, non-null = user's private ingredient
  user         User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  aliases      IngredientAlias[]
  ingredients  Ingredient[]

  @@index([userId])
}

model IngredientAlias {
  id        String            @id @default(uuid())
  alias     String            // lowercase; covers display name, synonyms, and stem variants
  catalogId String
  catalog   IngredientCatalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  userId    String?           // null = global/seeded, non-null = user's private alias
  user      User?             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([alias, userId])
  @@index([userId])
}

model MealRecipe {
  id            String   @id @default(uuid())
  mealPlanId    String
  mealPlan      MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  recipeId      String
  recipe        Recipe   @relation(fields: [recipeId], references: [id])
  recipeVersion Int      // Snapshot of version used
  servings      Int      // May be different from recipe default
  orderIndex    Int?
  substitutions Json?    // Record<ingredientId, { toIngredient: string; ratio: number }>
}

model GroceryItem {
  id         String   @id @default(uuid())
  mealPlanId String
  mealPlan   MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  ingredient String
  amount     Float?
  unit       String?
  purchased  Boolean  @default(false)
}

model UserPreferences {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  locale String @default("en-US")
  theme  String @default("light")
}
